{
  "name": "@nrql-js/nrql",
  "version": "0.2.2",
  "description": "NRQL parser Node.js bindings (NAPI-RS) for nom_nrql",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "nrql.js",
    "nrql.d.ts",
    "nrql-js.wasm",
    "index.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "license": "MIT OR Apache-2.0",
  "keywords": [
    "nrql",
    "newrelic",
    "parser",
    "napi-rs",
    "native",
    "query-language"
  ],
  "homepage": "https://github.com/bengreenier/nrql-js#readme",
  "bugs": {
    "url": "https://github.com/bengreenier/nrql-js/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bengreenier/nrql-js.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  },
  "napi": {
    "binaryName": "nrql-js",
    "targets": [
      "x86_64-pc-windows-msvc",
      "i686-pc-windows-msvc",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "armv7-unknown-linux-gnueabihf"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release --js nrql.js --dts nrql.d.ts",
    "build:wasm:unknown": "pnpm exec napi build --target wasm32-unknown-unknown --release --target-dir target || (echo \"napi build failed for wasm32-unknown-unknown, falling back to cargo artifact copy\" && cargo build --target wasm32-unknown-unknown --release --target-dir target && cp target/wasm32-unknown-unknown/release/nrql_js.wasm nrql-js.wasm)",
    "build:debug": "napi build --platform --js nrql.js --dts nrql.d.ts",
    "build:local": "napi build --release --dts nrql.d.ts",
    "check:wasm:unknown": "cargo check --target wasm32-unknown-unknown",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "node --test",
    "version": "napi version"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@napi-rs/cli": "^3.2.0"
  }
}
